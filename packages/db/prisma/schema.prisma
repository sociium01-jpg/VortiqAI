// --- RESTORED ENUMS & MODELS FROM STEP 39 ---

enum CallDirection {
  OUTBOUND
  INBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  VOICEMAIL
  FAILED
  COMPLETED
}

enum CallOutcome {
  INTERESTED
