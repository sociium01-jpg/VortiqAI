# Vapi (voice orchestration)
VAPI_API_KEY=your-vapi-api-key
VAPI_PHONE_NUMBER_ID=your-vapi-phone-id
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret

# ElevenLabs (TTS platform credentials)
ELEVENLABS_PLATFORM_KEY=your-elevenlabs-key
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM # Rachel voice

# Deepgram (STT)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Twilio (telephony fallback)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_140_SERIES_NUMBER=+911400000000 # TRAI Compliant Outbound Number
TWILIO_WEBHOOK_URL=your-twilio-webhook

# Exotel (India-specific 140 compliance calling)
EXOTEL_API_KEY=your-exotel-key
EXOTEL_API_SECRET=your-exotel-secret
EXOTEL_SID=your-exotel-sid
EXOTEL_140_NUMBER=+911401234567

# NCPR DND API (TRAI Do Not Disturb scrubbing register)
NCPR_API_KEY=your-ncpr-api-key
NCPR_API_URL=https://api.ncpr.in/v1

# Telegram bot integration
TELEGRAM_BOT_TOKEN=your-telegram-token
TELEGRAM_WEBHOOK_URL=your-telegram-webhook
TELEGRAM_ALLOWED_UPDATES=message,callback_query

# WhatsApp (Meta Cloud API v20.0+)
META_WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-id
META_WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
META_WEBHOOK_VERIFY_TOKEN=your-webhook-token
META_APP_SECRET=your-meta-app-secret

# People Data Labs
PEOPLE_DATA_LABS_API_KEY=your-pdl-key

# Hunter.io
HUNTER_API_KEY=your-hunter-key

# Proxycurl
PROXYCURL_API_KEY=your-proxycurl-key

# ZeroBounce
ZERO_BOUNCE_API_KEY=your-zerobounce-key

# Google APIs
GOOGLE_MAPS_API_KEY=your-maps-key
GOOGLE_ADS_DEVELOPER_TOKEN=your-ads-dev-token
GOOGLE_ADS_CLIENT_ID=your-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-ads-client-secret

# Meta Ads
META_ADS_APP_ID=your-meta-ads-id
META_ADS_APP_SECRET=your-meta-ads-secret

# LinkedIn Leads
LINKEDIN_CLIENT_ID=your-linkedin-id
LINKEDIN_CLIENT_SECRET=your-linkedin-secret

# GSTN (NIC GSP sandbox/production)
GSTN_CLIENT_ID=your-gstn-id
GSTN_CLIENT_SECRET=your-gstn-secret
GSTN_SANDBOX=true

# Razorpay payments
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Resend Transactional Email
RESEND_API_KEY=your-resend-key
RESEND_FROM_EMAIL=alerts@vortiq.in

# Database Config
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vortiq?schema=public

# Redis Event Bus URL
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-key
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=your-clerk-pub-key
CLERK_SECRET_KEY=your-clerk-secret-key
CLERK_WEBHOOK_SECRET=your-clerk-webhook-secret
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-pub-key

# Cloudflare R2 (90-day voice recording retention vault)
CLOUDFLARE_R2_ACCESS_KEY=your-r2-access-key
CLOUDFLARE_R2_SECRET_KEY=your-r2-secret-key
CLOUDFLARE_R2_BUCKET=vortiq-call-recordings
CLOUDFLARE_R2_ENDPOINT=https://your-endpoint.r2.cloudflarestorage.com

# Key Encryption (32-byte hexadecimal secret to encrypt connector keys)
API_KEY_ENCRYPTION_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# General Config
NEXT_PUBLIC_APP_URL=https://app.vortiq.in
API_URL=https://api.vortiq.in
NODE_ENV=production
